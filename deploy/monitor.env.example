# =============================================================================
# Sub2API 监控配置
# =============================================================================
# 复制此文件为 monitor.env 并填写实际值:
#   cp monitor.env.example monitor.env
# =============================================================================

# Bark 推送地址（必填）
# 格式: https://api.day.app/你的KEY
BARK_URL="https://api.day.app/YOUR_BARK_KEY"

# API 基础地址（必填，不带末尾斜杠）
API_BASE_URL="https://your-domain.com"

# 监控模型（默认读取渠道监控，必须已配置到渠道监控中）
TEST_MODEL="claude-opus-4-6"

# API 检查来源：
#   channel_monitor - 读取新渠道监控结果（推荐）
#   status_probe    - 读取旧服务状态探针 HTTP 接口
API_CHECK_SOURCE="channel_monitor"

# Health 检查超时（秒，默认 15）
TIMEOUT=15

# 服务状态接口超时（秒，默认 15）
API_TIMEOUT=15

# 服务状态接口路径（通常保持默认）
STATUS_API_PATH="/api/v1/status/models"

# 渠道监控结果超过该秒数视为未知状态
CHANNEL_MONITOR_STALE_SECONDS=1800

# 按渠道单独统计可用正常账号数，可用数 <= 该值时发送 Bark 告警
# 默认 2：Anthropic/OpenAI/Gemini/Antigravity/Kiro 任一渠道只剩 2 个可用正常账号即告警
CHANNEL_AVAILABLE_THRESHOLD=2

# 生产数据库容器配置，仅 API_CHECK_SOURCE=channel_monitor 或调度可用率检查时使用
PG_CONTAINER="sub2api-postgres"
PG_USER="sub2api"
PG_DB="sub2api"

# 失败后重试次数（默认 2，即首次+2次重试=共3次）
RETRY_COUNT=2

# 重试间隔（秒，默认 5）
RETRY_INTERVAL=5

# Bark 分组名
BARK_GROUP="sub2api"

# Bark 告警铃声
BARK_SOUND_ALERT="alarm"

# Bark 恢复铃声
BARK_SOUND_RECOVER="chord"

# 是否发送异常通知（默认 true）
BARK_NOTIFY_ALERT=true

# 是否发送恢复通知（默认 true）
BARK_NOTIFY_RECOVER=true
