# =============================================================================
# Sub2API 监控配置
# =============================================================================
# 复制此文件为 monitor.env 并填写实际值:
#   cp monitor.env.example monitor.env
# =============================================================================

# Bark 推送地址（必填）
# 格式: https://api.day.app/你的KEY
BARK_URL="https://api.day.app/YOUR_BARK_KEY"

# API 基础地址（必填，不带末尾斜杠）
API_BASE_URL="https://your-domain.com"

# 用于测试调用的 API Key（必填）
API_KEY="sk-your-test-api-key"

# 测试模型（默认 claude-opus-4-6）
TEST_MODEL="claude-opus-4-6"

# Health 检查超时（秒，默认 15）
TIMEOUT=15

# API 调用超时（秒，默认 60；建议保持 60，网络抖动明显时最多调到 90）
API_TIMEOUT=60

# 失败后重试次数（默认 2，即首次+2次重试=共3次）
RETRY_COUNT=2

# 重试间隔（秒，默认 5）
RETRY_INTERVAL=5

# Bark 分组名
BARK_GROUP="sub2api"

# Bark 告警铃声
BARK_SOUND_ALERT="alarm"

# Bark 恢复铃声
BARK_SOUND_RECOVER="chord"
